{
  "name": "taop-credit-bureau",
  "private": true,
  "version": "0.0.0",
  "description": "TAOP MVP — Agent Credit Bureau + LoRA Guilds (vertical demo slice)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "contracts:build": "hardhat compile",
    "contracts:test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy-local.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy-base-sepolia.ts --network baseSepolia",
    "sdk:build": "npm run build -w @taop/sdk",
    "backend:dev": "tsx watch packages/backend/src/server.ts",
    "backend:build": "esbuild packages/backend/src/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=packages/backend/dist/server.cjs",
    "demo:dev": "vite --config apps/demo/vite.config.ts",
    "demo:build": "vite build --config apps/demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "hardhat test"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pino": "^10.3.1",
    "swagger-ui-dist": "^5.32.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@tailwindcss/vite": "^4.1.14",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "chai": "^4.5.0",
    "esbuild": "^0.25.0",
    "hardhat": "^2.28.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}

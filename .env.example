# TAOP Pilot — copy to .env and fill in
# Public RPC (recommended for quick testing, no key needed):
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
#
# Or use your own (Infura, Alchemy, etc.):
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/<YOUR_INFURA_KEY>

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
DEPLOYER_PK=0x<YOUR_DEPLOYER_PRIVATE_KEY>
PINATA_API_KEY=<YOUR_PINATA_API_KEY>
PINATA_JWT=<YOUR_PINATA_JWT>
REPLICATE_API_TOKEN=<YOUR_REPLICATE_TOKEN>

{
  "name": "@taopp/sdk",
  "version": "0.1.1",
  "private": false,
  "description": "TypeScript SDK for TAOP (Agent Credit Bureau + Capability Registry) — early access for the testnet deployment",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lexagor/TAOP-protocol.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/lexagor/TAOP-protocol/issues"
  },
  "homepage": "https://github.com/lexagor/TAOP-protocol/tree/main/packages/sdk#readme",
  "license": "MIT",
  "keywords": [
    "taop",
    "agent",
    "reputation",
    "credit-bureau",
    "lora",
    "capability",
    "ethereum",
    "base",
    "sdk"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && npx esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:ethers",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ethers": "^6.13.5"
  }
}
